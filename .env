# ============================================
# 🌐 SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001

# ============================================
# 🗄️ DATABASE CONFIGURATION
# ============================================
# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://mrsami:Admin123@cluster0.9dniolf.mongodb.net/AfgFreelance-database
MONGODB_OPTIONS=retryWrites=true&w=majority&appName=Cluster0

# Database Name (extracted from URI for convenience)
DB_NAME=AfgFreelance-database

# ============================================
# 🔐 JWT AUTHENTICATION
# ============================================
# IMPORTANT: Change this in production!
JWT_SECRET=afg_freelance_super_secret_key_2026_change_me_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ============================================
# 📧 EMAIL CONFIGURATION (for future use)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@afgfreelance.com

# ============================================
# 👤 ADMIN USER (for first-time setup)
# ============================================
ADMIN_EMAIL=admin@afgfreelance.com
ADMIN_PASSWORD=Admin123!@#
ADMIN_FULLNAME=System Administrator

# ============================================
# 🔧 OTHER CONFIGURATIONS
# ============================================
# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=5242880  # 5MB
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Session
SESSION_SECRET=afg_freelance_session_secret_2026
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds

# ============================================
# ⚠️ SECURITY WARNING
# ============================================
# Never commit this file to GitHub!
# Always use environment variables in production.
# ============================================