<!-- views/index.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <h1>AfgFreelance Platform</h1>
        <p>Empowering Afghan Freelancers</p>
    </header>

    <main>
        <section class="members-section">
            <h2>Our Members</h2>
            <div class="members-grid">
                <% members.forEach(member => { %>
                    <div class="member-card">
                        <h3><%= member.name %></h3>
                        <p class="profession"><%= member.profession %></p>
                        <p class="experience">Experience: <%= member.experience %> years</p>
                        <p class="location">📍 <%= member.location %></p>
                        <span class="status <%= member.status.toLowerCase() %>">
                            <%= member.status %>
                        </span>
                    </div>
                <% }) %>
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 AfgFreelance. All rights reserved.</p>
    </footer>
</body>
</html>